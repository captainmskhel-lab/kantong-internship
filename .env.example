# ============================================================
# Kantong Internship — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local. Never expose SERVICE_ROLE or secrets to the browser.
# ============================================================

# Postgres connection string (Supabase: Project Settings → Database → Connection string → URI).
# Use the connection pooler URL for serverless/Vercel deployments.
DATABASE_URL=

# Supabase project URL + anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key. SERVER ONLY. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to sign treasurer session cookies (>= 32 random chars).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Secret used to sign member viewer session cookies (>= 32 random chars).
VIEWER_SESSION_SECRET=

# Extra secret required by `npm run admin:reset` so the recovery script cannot be
# run without operator intent. Any non-empty random string.
ADMIN_RESET_SECRET=
